{
  "redirects": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "header",
          "key": "x-forwarded-proto",
          "value": "http"
        }
      ],
      "destination": "https://mycgpacalculator.in/$1",
      "permanent": true
    },
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "www.mycgpacalculator.in"
        }
      ],
      "destination": "https://mycgpacalculator.in/$1",
      "permanent": true
    }
  ]
}
